@page "/"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject LordHelm.Web.WidgetState State
@inject IJSRuntime JS
@inject LordHelm.Execution.ApprovalGate ApprovalGate
@inject LordHelm.Orchestrator.IGoalRunner GoalRunner
@inject LordHelm.Orchestrator.Chat.IChatDispatcher Dispatcher
@inject LordHelm.Orchestrator.IModelCatalog ModelCatalog
@inject LordHelm.Orchestrator.HelmPreferenceState Preference
@inject LordHelm.Web.Layout.DashboardLayoutState Layout
@inject LordHelm.Web.Layout.LayoutPresetResolver Presets
@inject NavigationManager Nav
@inject ILogger<Home> Logger

<PageTitle>Lord Helm Command Center</PageTitle>

@* Unified orchestration panel — throne composer + resolved-model banner +
   layout admin buttons + conversation history + inline approvals all in
   one surface, always visible at the top. No external status strip. *@
<HelmChatPanel AgentCount="@(widgets.Count(w => w.BucketOf() == "Running"))"
               EditMode="@editMode"
               OnToggleEdit="ToggleEditMode"
               OnRestoreDefault="RestoreDefault"
               OnSpawnDemo="AddDemoWidget"
               OnClearCompleted="ClearCompleted" />

<div class="widget-grid @(editMode ? "edit-mode" : "")">
    @foreach (var e in _layout)
    {
        <WidgetFrame Title="@TitleFor(e.Id)"
                     Subtitle="@SubtitleFor(e.Id)"
                     Glyph="@GlyphFor(e.Id)"
                     Columns="@e.Columns"
                     Rows="@e.Rows"
                     EditMode="@editMode"
                     DragId="@e.Id"
                     OnDropReorder="(src) => HandleDrop(src, e.Id)">
            @WidgetFor(e.Id)
        </WidgetFrame>
    }
</div>

<div class="status-summary">
    @foreach (var bucket in Buckets)
    {
        var isActive = _activeFilter == bucket.Key;
        <button class="status-pill status-pill-@bucket.Key.ToLowerInvariant() @(isActive ? "active" : "")"
                title="@bucket.Description"
                @onclick="() => ToggleFilter(bucket.Key)">
            <span class="pill-icon">@bucket.Icon</span>
            <span class="pill-label">@bucket.Label</span>
            <span class="pill-count">@Count(bucket.Key)</span>
        </button>
    }
    @if (_activeFilter is not null)
    {
        <button class="status-pill clear-filter" @onclick="() => ToggleFilter(null)">clear filter</button>
    }
</div>

@foreach (var bucket in Buckets.Where(b => ShouldShow(b.Key)))
{
    var items = WidgetsIn(bucket.Key);
    if (items.Count == 0) continue;
    var collapsed = IsCollapsed(bucket.Key);

    <section class="status-group status-group-@bucket.Key.ToLowerInvariant() @(collapsed ? "collapsed" : "")">
        <header class="group-head" @onclick="() => ToggleCollapsed(bucket.Key)" style="cursor:pointer" title="Click to @(collapsed ? "expand" : "collapse")">
            <span class="group-chevron">@(collapsed ? "▶" : "▼")</span>
            <span class="group-icon">@bucket.Icon</span>
            <span class="group-label">@bucket.Label</span>
            <span class="group-count">@items.Count</span>
            <span class="group-blurb">@bucket.Description</span>
            @if (bucket.Key is "Completed" or "Failed")
            {
                <button class="lh-ghost-btn group-clear"
                        @onclick="() => ClearBucket(bucket.Key)"
                        @onclick:stopPropagation
                        title="Remove all @bucket.Label items">clear</button>
            }
        </header>
        @if (!collapsed)
        {
        <div class="widget-grid status-group-grid">
            @foreach (var w in items)
            {
                <WidgetFrame Title="@w.Label"
                             Subtitle="@w.Status"
                             Glyph="@IconFor(w)"
                             Columns="@ColumnsFor(w)"
                             Rows="2">
                    <HeadActions>
                        <button class="lh-hue-@HueFor(w)" @onclick="() => Expand(w)" title="Expand log">⊞</button>
                    </HeadActions>
                    <ChildContent>
                        <div class="widget-tile-body @CssFor(w) @(w.NeedsAttention() ? "needs-attention" : "")">
                            @if (w.Tail is { Count: > 0 })
                            {
                                <pre class="log mono">@RenderTail(w.Tail.TakeLast(10))</pre>
                            }
                            else
                            {
                                <div class="placeholder">waiting for output...</div>
                            }
                            @if (w.Kind == LordHelm.Web.WidgetKind.Approval && w.PendingApproval is not null)
                            {
                                <div class="approval-actions">
                                    <button class="approve" @onclick="() => Approve(w)">approve</button>
                                    <button class="deny" @onclick="() => Deny(w)">deny</button>
                                </div>
                            }
                            @if (w.BucketOf() == "Running" && w.Kind == LordHelm.Web.WidgetKind.Task)
                            {
                                var tierKey = GetOrInit(redirectTier, w.Id, "Deep");
                                var vendorKey = GetOrInit(redirectVendor, w.Id, "");
                                <div class="task-redirect" title="Redirect: apply a different tier / vendor to subsequent dispatches">
                                    <select value="@tierKey" @onchange="e => redirectTier[w.Id] = e.Value?.ToString() ?? tierKey">
                                        <option value="Deep">deep</option>
                                        <option value="Fast">fast</option>
                                        <option value="Code">code</option>
                                    </select>
                                    <select value="@vendorKey" @onchange="e => redirectVendor[w.Id] = e.Value?.ToString() ?? vendorKey">
                                        <option value="">auto</option>
                                        <option value="claude">claude</option>
                                        <option value="gemini">gemini</option>
                                        <option value="codex">codex</option>
                                    </select>
                                    <button @onclick="() => RedirectTask(w)">apply</button>
                                </div>
                            }
                            <div class="widget-foot">
                                <span class="mono">@(w.Env?.ToString() ?? w.Kind.ToString())</span>
                                <span class="mono">@w.UpdatedAt.ToLocalTime().ToString("HH:mm:ss")</span>
                            </div>
                        </div>
                    </ChildContent>
                </WidgetFrame>
            }
        </div>
        }
    </section>
}

@if (!widgets.Any())
{
    <div class="empty-overlay">No active threads. Submit a goal above or click "+ spawn".</div>
}

@if (expanded is not null)
{
    <div class="log-modal-backdrop" @onclick="CloseExpand">
        <div class="log-modal" @onclick:stopPropagation>
            <div class="widget-head">
                <span class="icon">@IconFor(expanded)</span>
                <span class="label">@expanded.Label</span>
                <span class="status">@expanded.Status <small>(live)</small></span>
                <button class="close" @onclick="CloseExpand">x</button>
            </div>
            <div class="widget-body">
                <pre class="log">@RenderTail(liveLines.Count > 0 ? liveLines : (expanded.Tail ?? Array.Empty<string>()))</pre>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<LordHelm.Web.WidgetModel> widgets = Array.Empty<LordHelm.Web.WidgetModel>();
    private IReadOnlyList<LordHelm.Web.Layout.LayoutEntry> _layout = Array.Empty<LordHelm.Web.Layout.LayoutEntry>();
    private LordHelm.Web.WidgetModel? expanded;
    private DotNetObjectReference<Home>? _selfRef;
    private int? _sseSubscription;
    private readonly List<string> liveLines = new();
    private const int LiveLinesCap = 400;
    private bool editMode;
    private string? _activeFilter;
    private readonly Dictionary<string, string> redirectTier = new();
    private readonly Dictionary<string, string> redirectVendor = new();

    // Completed + Failed start collapsed so the grid doesn't get drowned in
    // historical tiles. Incidents/Approvals/Running always open by default —
    // those are the attention-warranting buckets.
    private readonly HashSet<string> _collapsedBuckets = new(StringComparer.OrdinalIgnoreCase) { "Completed", "Failed" };

    private bool IsCollapsed(string key) => _collapsedBuckets.Contains(key);
    private void ToggleCollapsed(string key)
    {
        if (!_collapsedBuckets.Add(key)) _collapsedBuckets.Remove(key);
    }
    private void ClearBucket(string key)
    {
        foreach (var w in widgets.Where(w => w.BucketOf() == key).ToList())
            State.Remove(w.Id);
    }

    private void ToggleEditMode() => editMode = !editMode;
    private void RestoreDefault() { Layout.RestoreDefault(); _layout = Layout.Entries; }

    private void HandleDrop(string sourceId, string targetId)
    {
        if (sourceId == targetId) return;
        var entries = Layout.Entries;
        var si = entries.Select((e, i) => (e, i)).FirstOrDefault(p => p.e.Id == sourceId).i;
        var ti = entries.Select((e, i) => (e, i)).FirstOrDefault(p => p.e.Id == targetId).i;
        Layout.SwapByIndex(si, ti);
        _layout = Layout.Entries;
    }

    private static string TitleFor(string id) => id switch
    {
        "topology"  => "Topology",
        "fleet"     => "Fleet Roster",
        "active"    => "Active Agent",
        "kpis"      => "KPIs",
        "gantt"     => "Timeline",
        "queue"     => "Task Queue",
        "alerts"    => "Alerts",
        "approvals" => "Approvals",
        "recent"    => "Recent",
        "health"    => "System Health",
        "providers" => "Providers",
        "artifacts" => "Artifacts",
        _ => id,
    };

    private static string? SubtitleFor(string id) => id switch
    {
        "topology"  => "live fleet graph",
        "providers" => "rolling usage vs limit",
        _ => null,
    };

    private static string GlyphFor(string id) => id switch
    {
        "topology"  => "⬡",
        "fleet"     => "♟",
        "active"    => "◎",
        "kpis"      => "▲",
        "gantt"     => "▬",
        "queue"     => "▤",
        "alerts"    => "⚠",
        "approvals" => "✓",
        "recent"    => "↺",
        "health"    => "◉",
        "providers" => "◎",
        "artifacts" => "◫",
        _ => "·",
    };

    private RenderFragment WidgetFor(string id) => builder =>
    {
        switch (id)
        {
            case "topology":  builder.OpenComponent<TopologyWidget>(0);       builder.CloseComponent(); break;
            case "fleet":     builder.OpenComponent<FleetRosterWidget>(0);    builder.CloseComponent(); break;
            case "active":    builder.OpenComponent<ActiveAgentWidget>(0);    builder.CloseComponent(); break;
            case "kpis":      builder.OpenComponent<KpisWidget>(0);           builder.CloseComponent(); break;
            case "gantt":     builder.OpenComponent<GanttWidget>(0);          builder.CloseComponent(); break;
            case "queue":     builder.OpenComponent<QueueWidget>(0);          builder.CloseComponent(); break;
            case "alerts":    builder.OpenComponent<AlertsWidget>(0);         builder.CloseComponent(); break;
            case "approvals": builder.OpenComponent<ApprovalsWidget>(0);      builder.CloseComponent(); break;
            case "recent":    builder.OpenComponent<RecentWidget>(0);         builder.CloseComponent(); break;
            case "health":    builder.OpenComponent<HealthWidget>(0);         builder.CloseComponent(); break;
            case "providers": builder.OpenComponent<ProvidersMiniWidget>(0);  builder.CloseComponent(); break;
            case "artifacts": builder.OpenComponent<ArtifactsWidget>(0);      builder.CloseComponent(); break;
        }
    };

    private static string GetOrInit(Dictionary<string, string> map, string key, string defaultValue)
    {
        if (!map.TryGetValue(key, out var v)) { map[key] = defaultValue; return defaultValue; }
        return v;
    }

    private void RedirectTask(LordHelm.Web.WidgetModel w)
    {
        // Widget-level redirect now flows through the shared HelmPreference so
        // the orchestration panel's selectors and future dispatches all pick up
        // the new vendor/tier without per-component state threading.
        var tier   = redirectTier.GetValueOrDefault(w.Id, "Deep");
        var vendor = redirectVendor.GetValueOrDefault(w.Id, "");
        if (!string.IsNullOrEmpty(vendor))
            Preference.SetPrimary(vendor, model: null, tier: tier);
    }

    // ---- status buckets: attention-ordered ----
    private record Bucket(string Key, string Label, string Icon, string Description);

    private static readonly IReadOnlyList<Bucket> Buckets = new Bucket[]
    {
        new("Incident",  "Incidents",  "!",       "paused threads awaiting Consensus Protocol"),
        new("Approval",  "Approvals",  "[?]",     "host actions waiting for operator approve / deny"),
        new("Running",   "Running",    "[>]",     "actively executing tasks and subprocesses"),
        new("Completed", "Completed",  "[v]",     "tasks that finished successfully"),
        new("Failed",    "Failed",     "[x]",     "tasks or subprocesses that exited non-zero"),
    };

    private bool ShouldShow(string key) => _activeFilter is null || _activeFilter == key;

    private void ToggleFilter(string? key)
    {
        _activeFilter = _activeFilter == key ? null : key;
    }

    private int Count(string key) => WidgetsIn(key).Count;

    private IReadOnlyList<LordHelm.Web.WidgetModel> WidgetsIn(string key)
    {
        return key switch
        {
            "Incident"  => widgets.Where(w => w.BucketOf() == "Incident").ToList(),
            "Approval"  => widgets.Where(w => w.BucketOf() == "Approval").ToList(),
            "Running"   => widgets.Where(w => w.BucketOf() == "Running").ToList(),
            "Completed" => widgets.Where(w => w.BucketOf() == "Completed").ToList(),
            "Failed"    => widgets.Where(w => w.BucketOf() == "Failed").ToList(),
            _ => Array.Empty<LordHelm.Web.WidgetModel>(),
        };
    }

    // ---- lifecycle ----
    protected override void OnInitialized()
    {
        widgets = State.Snapshot();
        _layout = Layout.Entries;
        State.OnChanged += HandleChanged;
        Layout.OnChanged += HandleLayoutChanged;
    }

    private void HandleLayoutChanged()
    {
        _layout = Layout.Entries;
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
        }
        await Task.CompletedTask;
    }

    [JSInvokable]
    public Task ReloadWidgets()
    {
        widgets = State.Snapshot();
        return InvokeAsync(StateHasChanged);
    }

    private void HandleChanged()
    {
        widgets = State.Snapshot();
        if (expanded is not null)
        {
            expanded = widgets.FirstOrDefault(w => w.Id == expanded.Id) ?? expanded;
        }
        InvokeAsync(StateHasChanged);
    }

    private void AddDemoWidget()
    {
        var id = "demo-" + Guid.NewGuid().ToString("N")[..6];
        var env = Random.Shared.Next(3) switch
        {
            0 => LordHelm.Core.ExecutionEnvironment.Host,
            1 => LordHelm.Core.ExecutionEnvironment.Docker,
            _ => LordHelm.Core.ExecutionEnvironment.Docker,
        };
        var label = env switch
        {
            LordHelm.Core.ExecutionEnvironment.Docker => "sandbox: exec-python",
            _ => "host: read-file",
        };
        State.SpawnDemo(id, label, env);
    }

    private void ClearCompleted()
    {
        foreach (var w in widgets.Where(w => w.BucketOf() is "Completed" or "Failed").ToList())
        {
            State.Remove(w.Id);
        }
    }

    private void ResetLayout() { /* grid layout no longer via gridstack; left as no-op */ }

    private async Task Expand(LordHelm.Web.WidgetModel w)
    {
        expanded = w;
        liveLines.Clear();
        if (_sseSubscription is int old) { try { await JS.InvokeVoidAsync("helmSse.unsubscribe", old); } catch { } }
        try
        {
            _sseSubscription = await JS.InvokeAsync<int>("helmSse.subscribe", w.Id, _selfRef!, nameof(OnSseLines));
        }
        catch (JSException) { _sseSubscription = null; }
    }

    private async Task CloseExpand()
    {
        expanded = null;
        liveLines.Clear();
        if (_sseSubscription is int id)
        {
            try { await JS.InvokeVoidAsync("helmSse.unsubscribe", id); } catch { }
            _sseSubscription = null;
        }
    }

    [JSInvokable]
    public Task OnSseLines(string[] payloads)
    {
        foreach (var payload in payloads)
        {
            liveLines.Add(payload);
            if (liveLines.Count > LiveLinesCap)
                liveLines.RemoveRange(0, liveLines.Count - LiveLinesCap);
        }
        return InvokeAsync(StateHasChanged);
    }

    private void Approve(LordHelm.Web.WidgetModel w)
        => State.ResolveApproval(w.Id, approved: true, "operator approved via dashboard", ApprovalGate);
    private void Deny(LordHelm.Web.WidgetModel w)
        => State.ResolveApproval(w.Id, approved: false, "operator denied via dashboard", ApprovalGate);

    private static string CssFor(LordHelm.Web.WidgetModel w) => w.Kind switch
    {
        LordHelm.Web.WidgetKind.Approval => "approval",
        LordHelm.Web.WidgetKind.Task => w.Status switch
        {
            "completed" => "completed",
            "failed" => "incident",
            _ => "task",
        },
        _ => w.Status switch
        {
            "incident" => "incident",
            "completed" => "completed",
            _ when w.Env == LordHelm.Core.ExecutionEnvironment.Docker => "sandbox",
            _ => "host",
        },
    };

    private static string IconFor(LordHelm.Web.WidgetModel w) => w.Kind switch
    {
        LordHelm.Web.WidgetKind.Approval => "✓",
        LordHelm.Web.WidgetKind.Task => "◎",
        _ => w.Status switch
        {
            "incident" => "!",
            _ when w.Env == LordHelm.Core.ExecutionEnvironment.Docker => "⬢",
            _ => "◈",
        },
    };

    private static int ColumnsFor(LordHelm.Web.WidgetModel w) => w.Kind switch
    {
        LordHelm.Web.WidgetKind.Approval => 4,
        LordHelm.Web.WidgetKind.Task     => 4,
        LordHelm.Web.WidgetKind.Incident => 6,
        _                                => 3,
    };

    private static string HueFor(LordHelm.Web.WidgetModel w) => w.Kind switch
    {
        LordHelm.Web.WidgetKind.Approval when w.Status is "pending-approval" => "warn",
        LordHelm.Web.WidgetKind.Incident => "err",
        _ => w.Status switch
        {
            "completed" => "ok",
            "failed"    => "err",
            "incident"  => "err",
            _           => "brand",
        },
    };

    // HandleQuickAction was the old quick-action fallback when the Throne
    // owned the goal bar; HelmChatPanel now handles its own dispatch and
    // preset matching lives on the /widgets page, so this is obsolete.

    private static MarkupString RenderTail(IEnumerable<string> lines)
    {
        var sb = new System.Text.StringBuilder();
        foreach (var line in lines)
        {
            var klass =
                line.StartsWith("[HOST]") || line.StartsWith("[OUT]") ? "host" :
                line.StartsWith("[SANDBOX]") ? "sandbox" :
                line.StartsWith("[ERR]") || line.Contains("error", StringComparison.OrdinalIgnoreCase) ? "err" :
                "";
            var escaped = System.Net.WebUtility.HtmlEncode(line);
            sb.Append($"<span class='{klass}'>{escaped}</span>\n");
        }
        return new MarkupString(sb.ToString());
    }

    public ValueTask DisposeAsync()
    {
        State.OnChanged -= HandleChanged;
        _selfRef?.Dispose();
        return ValueTask.CompletedTask;
    }
}
