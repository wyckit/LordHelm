@page "/alerts"
@rendermode InteractiveServer
@implements IDisposable
@inject LordHelm.Core.IAlertTray Tray

<PageTitle>Lord Helm — Alerts (@Tray.UnreadCount)</PageTitle>

<header class="helm-header">
    <h1>Alerts <span class="subtitle">@Tray.UnreadCount unread of @all.Count total</span></h1>
    <div class="helm-toolbar">
        <button @onclick="MarkAllRead" title="Mark every alert as read">mark all read</button>
        <button @onclick="Clear" title="Purge the tray">clear</button>
    </div>
</header>

<section class="mgmt-body">
    @if (all.Count == 0)
    {
        <div class="empty-panel">No alerts yet. Overseer agents and incident responses surface here.</div>
    }
    else
    {
        @foreach (var bucket in Buckets)
        {
            var items = all.Where(a => a.Kind == bucket.Kind).ToList();
            if (items.Count == 0) continue;

            <div class="alert-bucket alert-bucket-@bucket.Kind.ToString().ToLowerInvariant()">
                <div class="alert-bucket-head">
                    <span>@bucket.Label</span>
                    <span class="bucket-count">@items.Count</span>
                    @if (items.Any(i => !i.Read))
                    {
                        <button class="bucket-action" @onclick="() => MarkBucketRead(bucket.Kind)">mark group read</button>
                    }
                </div>
                <div class="alerts-list">
                @foreach (var a in items)
                {
                    <div class="alert-card alert-@a.Kind.ToString().ToLowerInvariant() @(a.Read ? "read" : "unread")"
                         @onclick="() => MarkRead(a.Id)">
                        <div class="alert-head">
                            <span class="alert-kind">@a.Kind</span>
                            <span class="alert-source">@a.Source</span>
                            <span class="alert-time">@a.At.ToLocalTime().ToString("HH:mm:ss")</span>
                        </div>
                        <div class="alert-title">@a.Title</div>
                        <pre class="alert-body">@a.Body</pre>
                    </div>
                }
                </div>
            </div>
        }
    }
</section>

@code {
    private record Bucket(LordHelm.Core.AlertKind Kind, string Label);

    // Severity order: Error > Attention > Warning > DoneForNow > Info
    private static readonly IReadOnlyList<Bucket> Buckets = new Bucket[]
    {
        new(LordHelm.Core.AlertKind.Error,      "Errors"),
        new(LordHelm.Core.AlertKind.Attention,  "Needs Attention"),
        new(LordHelm.Core.AlertKind.Warning,    "Warnings"),
        new(LordHelm.Core.AlertKind.DoneForNow, "Done For Now"),
        new(LordHelm.Core.AlertKind.Info,       "Info"),
    };

    private IReadOnlyList<LordHelm.Core.AlertEntry> all = Array.Empty<LordHelm.Core.AlertEntry>();

    protected override void OnInitialized()
    {
        all = Tray.All();
        Tray.OnChanged += HandleChanged;
    }

    private void HandleChanged()
    {
        all = Tray.All();
        InvokeAsync(StateHasChanged);
    }

    private async Task MarkRead(string id) => await Tray.MarkReadAsync(id);
    private async Task MarkAllRead() => await Tray.MarkAllReadAsync();
    private async Task Clear() => await Tray.ClearAsync();

    private async Task MarkBucketRead(LordHelm.Core.AlertKind kind)
    {
        foreach (var a in all.Where(a => a.Kind == kind && !a.Read))
            await Tray.MarkReadAsync(a.Id);
    }

    public void Dispose() => Tray.OnChanged -= HandleChanged;
}
