@page "/skills"
@rendermode InteractiveServer
@inject LordHelm.Skills.ISkillCache Cache
@inject IEnumerable<LordHelm.Skills.Export.ISkillExporter> Exporters
@inject NavigationManager Nav

<PageTitle>Lord Helm — Skills</PageTitle>

<header class="helm-header">
    <h1>Skills <span class="subtitle">@skills.Count loaded</span></h1>
</header>

<section class="mgmt-body">
    <div class="skills-export" style="margin-bottom:14px; padding:10px 12px; background:rgba(20,22,32,0.5); border:1px solid var(--panel-edge); border-radius:6px">
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:6px">
            <strong style="font-size:11px; letter-spacing:1.5px; text-transform:uppercase; color:var(--muted)">push to cli</strong>
            <label style="font-size:10px; color:var(--muted)">
                <input type="checkbox" @bind="_overwrite" /> overwrite existing
            </label>
        </div>
        <div style="display:flex; flex-wrap:wrap; gap:8px">
            @foreach (var exp in _exporters)
            {
                var last = _lastExport.TryGetValue(exp.VendorId, out var r) ? r : null;
                var supported = exp.IsSupported();
                <button class="lh-ghost-btn" style="font-size:11px"
                        @onclick="() => Export(exp)"
                        disabled="@(!supported || _busy.Contains(exp.VendorId))">
                    @if (_busy.Contains(exp.VendorId)) { <text>syncing @exp.VendorId…</text> }
                    else { <text>sync → @exp.VendorId</text> }
                </button>
                @if (last is not null)
                {
                    <span class="mono" style="font-size:10px; color:@(last.Errors.Count > 0 ? "var(--incident-1)" : "var(--sandbox-2)")">
                        @exp.VendorId: @last.Written written · @last.Skipped skipped@(last.Errors.Count > 0 ? $" · {last.Errors.Count} err" : "")
                    </span>
                }
                @if (!supported)
                {
                    <span class="muted" style="font-size:10px">@exp.VendorId unsupported</span>
                }
            }
        </div>
        @if (_exporters.Any(e => e.IsSupported() && !string.IsNullOrEmpty(e.TargetDirectory)))
        {
            <div class="muted" style="font-size:10px; margin-top:6px">
                target:
                @foreach (var e in _exporters.Where(e => e.IsSupported() && !string.IsNullOrEmpty(e.TargetDirectory)))
                {
                    <code style="margin-right:10px">@e.TargetDirectory</code>
                }
            </div>
        }
    </div>

    @if (skills.Count == 0)
    {
        <div class="empty-panel">
            No skills loaded yet. Check that the <code>skills/</code> directory exists at the repo root
            and contains valid <code>.skill.xml</code> files.
        </div>
    }
    else
    {
        <table class="mgmt-table">
            <thead>
                <tr>
                    <th>Id</th><th>Version</th><th>Env</th><th>Risk</th><th>Timeout</th><th>MinTrust</th><th>Hash</th><th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var s in skills)
            {
                <tr>
                    <td><strong>@s.Id</strong></td>
                    <td>@s.Version</td>
                    <td class="env-@s.ExecEnv.ToString().ToLowerInvariant()">@s.ExecEnv</td>
                    <td>@s.RiskTier</td>
                    <td>@s.Timeout</td>
                    <td>@s.MinTrust</td>
                    <td class="mono">@s.ContentHashSha256.Substring(0, 12)...</td>
                    <td>
                        <button class="run-skill" @onclick="() => RunSkill(s)" title="Prefill the goal bar with an invocation for this skill">run</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>

@code {
    private IReadOnlyList<LordHelm.Core.SkillManifest> skills = Array.Empty<LordHelm.Core.SkillManifest>();
    private IReadOnlyList<LordHelm.Skills.Export.ISkillExporter> _exporters = Array.Empty<LordHelm.Skills.Export.ISkillExporter>();
    private readonly Dictionary<string, LordHelm.Skills.Export.ExportReport> _lastExport = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _busy = new(StringComparer.OrdinalIgnoreCase);
    private bool _overwrite = false;

    protected override async Task OnInitializedAsync()
    {
        await Cache.InitializeAsync();
        skills = await Cache.ListAsync();
        _exporters = Exporters.ToList();
    }

    private async Task Export(LordHelm.Skills.Export.ISkillExporter exporter)
    {
        if (_busy.Contains(exporter.VendorId)) return;
        _busy.Add(exporter.VendorId);
        StateHasChanged();
        try
        {
            var report = await exporter.ExportAsync(skills, _overwrite);
            _lastExport[exporter.VendorId] = report;
        }
        finally
        {
            _busy.Remove(exporter.VendorId);
            StateHasChanged();
        }
    }

    private void RunSkill(LordHelm.Core.SkillManifest s)
    {
        // Prefill the dashboard goal bar via a query param so the operator lands on
        // the ready-to-dispatch form. Home.razor reads ?goal=... from the URL.
        var template = s.Id switch
        {
            "read-file"         => $"use the {s.Id} skill to read a file",
            "execute-python"    => $"use the {s.Id} skill to run a small python snippet",
            "write-engram-node" => $"use the {s.Id} skill to record a note in engram",
            _ => $"invoke the {s.Id} skill",
        };
        Nav.NavigateTo($"/?goal={Uri.EscapeDataString(template)}", forceLoad: false);
    }
}
