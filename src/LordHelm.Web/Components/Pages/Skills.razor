@page "/skills"
@rendermode InteractiveServer
@inject LordHelm.Skills.ISkillCache Cache
@inject NavigationManager Nav

<PageTitle>Lord Helm — Skills</PageTitle>

<header class="helm-header">
    <h1>Skills <span class="subtitle">@skills.Count loaded</span></h1>
</header>

<section class="mgmt-body">
    @if (skills.Count == 0)
    {
        <div class="empty-panel">
            No skills loaded yet. Check that the <code>skills/</code> directory exists at the repo root
            and contains valid <code>.skill.xml</code> files.
        </div>
    }
    else
    {
        <table class="mgmt-table">
            <thead>
                <tr>
                    <th>Id</th><th>Version</th><th>Env</th><th>Risk</th><th>Timeout</th><th>MinTrust</th><th>Hash</th><th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var s in skills)
            {
                <tr>
                    <td><strong>@s.Id</strong></td>
                    <td>@s.Version</td>
                    <td class="env-@s.ExecEnv.ToString().ToLowerInvariant()">@s.ExecEnv</td>
                    <td>@s.RiskTier</td>
                    <td>@s.Timeout</td>
                    <td>@s.MinTrust</td>
                    <td class="mono">@s.ContentHashSha256.Substring(0, 12)...</td>
                    <td>
                        <button class="run-skill" @onclick="() => RunSkill(s)" title="Prefill the goal bar with an invocation for this skill">run</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>

@code {
    private IReadOnlyList<LordHelm.Core.SkillManifest> skills = Array.Empty<LordHelm.Core.SkillManifest>();

    protected override async Task OnInitializedAsync()
    {
        await Cache.InitializeAsync();
        skills = await Cache.ListAsync();
    }

    private void RunSkill(LordHelm.Core.SkillManifest s)
    {
        // Prefill the dashboard goal bar via a query param so the operator lands on
        // the ready-to-dispatch form. Home.razor reads ?goal=... from the URL.
        var template = s.Id switch
        {
            "read-file"         => $"use the {s.Id} skill to read a file",
            "execute-python"    => $"use the {s.Id} skill to run a small python snippet",
            "write-engram-node" => $"use the {s.Id} skill to record a note in engram",
            _ => $"invoke the {s.Id} skill",
        };
        Nav.NavigateTo($"/?goal={Uri.EscapeDataString(template)}", forceLoad: false);
    }
}
