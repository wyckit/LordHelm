@inherits LayoutComponentBase
@implements IDisposable
@inject LordHelm.Core.IAlertTray Tray
@inject LordHelm.Orchestrator.Usage.UsageProbeService UsageProbe
@inject LordHelm.Orchestrator.ModelDiscovery.ModelCatalogRefresher ModelRefresh

<header class="lh-header">
    <button class="lh-refresh" @onclick="RefreshAll" disabled="@refreshing"
            title="Re-probe vendors for subscription status + refresh the model catalog (usage auto-runs every 5 min; models every 6 h)">
        @(refreshing ? "⟳" : "↻")
    </button>
    <a href="/" class="lh-brand">
        <span class="lh-crest">L</span>
        <span class="lh-wordmark">Lord Helm</span>
    </a>
    <nav class="lh-nav">
        <a href="/">dashboard</a>
        <a href="/skills">skills</a>
        <a href="/experts">experts</a>
        <a href="/overseers">overseers</a>
        <a href="/providers">providers</a>
        <a href="/models">models</a>
        <a href="/models/probes" title="Edit CLI probe incantations">probes</a>
        <a href="/routing" title="Adapter score breakdown for a request">routing</a>
        <a href="/diagnostics" title="Live ping every CLI + routing scorecard">diag</a>
        <a href="/widgets">widgets</a>
        <a href="/cortex" title="Lord Helm's staged thoughts — approve or let them settle">cortex</a>
    </nav>
    <div class="lh-header-right">
        <a href="/alerts" class="lh-alerts-link">
            alerts
            @if (unread > 0)
            {
                <span class="alert-badge">@unread</span>
            }
        </a>
    </div>
</header>

<SummaryRibbon />

@Body

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x1F5D9;</span>
</div>

@code {
    private int unread;
    private bool refreshing;

    protected override void OnInitialized()
    {
        unread = Tray.UnreadCount;
        Tray.OnChanged += HandleChanged;
    }

    private void HandleChanged()
    {
        unread = Tray.UnreadCount;
        InvokeAsync(StateHasChanged);
    }

    // One click re-probes both subscription status AND the model catalog so
    // stale vendor model lists (e.g. codex) pick up the latest entries on demand.
    private async Task RefreshAll()
    {
        if (refreshing) return;
        refreshing = true;
        StateHasChanged();
        try
        {
            await Task.WhenAll(
                UsageProbe.RefreshAllAsync(),
                ModelRefresh.RefreshAllAsync());
        }
        catch { /* errors surface via UsageState.OnChanged / catalog OnChanged */ }
        finally { refreshing = false; StateHasChanged(); }
    }

    public void Dispose() => Tray.OnChanged -= HandleChanged;
}
